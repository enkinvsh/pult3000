{
  "manifest_version": 3,
  "name": "Kaset Volume",
  "version": "1.0",
  "description": "Volume control for YouTube Music",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://music.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Volume"
  },
  "content_scripts": [
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
