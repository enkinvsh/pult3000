{
  "manifest_version": 3,
  "name": "Kaset Volume Control",
  "version": "1.0",
  "description": "Controls YouTube Music volume for Kaset bot",
  "host_permissions": ["*://music.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
